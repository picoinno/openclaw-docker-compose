# ============================================================
# OpenClaw Stack — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git!
# ============================================================


# =====================
# REQUIRED
# =====================

# --- Tailscale VPN ---
# You need a Tailscale account: https://tailscale.com
# Generate an auth key at: https://login.tailscale.com/admin/settings/keys
# Use "Reusable" so container can reconnect after restart
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tailscale hostname — this is how the machine appears in your Tailscale dashboard
# Also used to access the Control UI: http://<hostname>:18789
# Change this to something unique if running multiple instances
TS_HOSTNAME=openclaw-agent

# --- OpenClaw Gateway ---
# Token for Control UI authentication
# Generate: openssl rand -hex 32
OPENCLAW_TOKEN=

# --- AI Provider (at least one required) ---
# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- AI Model ---
# Must match your provider. Run ./scripts/init-config.sh after first boot.
# Examples:
#   anthropic/claude-sonnet-4-20250514   (Anthropic)
#   openai/gpt-4o                        (OpenAI)
#   openrouter/anthropic/claude-3.5-sonnet (OpenRouter)
#   ollama/llama3                         (Ollama)
AI_MODEL=anthropic/claude-sonnet-4-20250514

# --- Telegram Bot ---
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz


# =====================
# OPTIONAL — AI Providers
# =====================

# OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-key-here

# OpenRouter (100+ models): https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-your-key-here

# Google Gemini: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-key-here

# Groq (fast inference): https://console.groq.com/keys
# GROQ_API_KEY=gsk_your-key-here

# Mistral: https://console.mistral.ai/api-keys
# MISTRAL_API_KEY=your-key-here

# Together AI: https://api.together.xyz/settings/api-keys
# TOGETHER_API_KEY=your-key-here

# NVIDIA: https://build.nvidia.com/
# NVIDIA_API_KEY=nvapi-your-key-here

# Perplexity (search-powered): https://www.perplexity.ai/settings/api
# PERPLEXITY_API_KEY=pplx-your-key-here

# Moonshot / Kimi: https://platform.moonshot.cn/console/api-keys
# MOONSHOT_API_KEY=sk-your-key-here

# Venice AI (privacy-focused): https://venice.ai/settings/api
# VENICE_API_KEY=your-key-here

# Hugging Face: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your-token-here

# Kilocode: https://kilocode.ai
# KILOCODE_API_KEY=your-key-here

# Deepgram (speech-to-text): https://console.deepgram.com/
# DEEPGRAM_API_KEY=your-key-here

# MiniMax: https://www.minimaxi.com/
# MINIMAX_API_KEY=your-key-here
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Xiaomi
# XIAOMI_API_KEY=your-key-here

# ZAI
# ZAI_API_KEY=your-key-here

# Amazon Bedrock (uses AWS credentials, not env key)
# See: https://docs.openclaw.ai/providers/bedrock

# OpenAI-compatible (Ollama, vLLM, LiteLLM, sglang)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_TTS_BASE_URL=http://localhost:8880/v1

# LiteLLM (unified gateway)
# LITELLM_API_KEY=sk-your-key-here


# =====================
# OPTIONAL — Tools & Services
# =====================

# Brave Search: https://brave.com/search/api/
# BRAVE_API_KEY=BSA-your-key-here

# ElevenLabs (TTS): https://elevenlabs.io
# ELEVENLABS_API_KEY=your-key-here
# ELEVENLABS_VOICE_ID=your-preferred-voice-id

# Firecrawl (web scraping)
# FIRECRAWL_API_KEY=fc-your-key-here


# =====================
# OPTIONAL — Gateway Settings
# =====================

# OPENCLAW_GATEWAY_BIND=lan
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_LOG_LEVEL=info


# =====================
# OPTIONAL — Browser Engine
# =====================

# MAX_CONCURRENT_SESSIONS=3
# CONNECTION_TIMEOUT=300000


# =====================
# OPTIONAL — Additional Channels
# =====================
# See docs: https://docs.openclaw.ai/channels

# Discord: https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your-discord-bot-token

# Slack: https://api.slack.com/apps
# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_APP_TOKEN=xapp-your-token

# Signal: https://docs.openclaw.ai/channels/signal
