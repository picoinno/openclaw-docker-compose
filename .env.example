# ============================================================
# OpenClaw Stack — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# Everything else is optional.
# ============================================================

# --- Core Security ---

# [REQUIRED] Gateway auth token — used for Control UI access
# Generate one: openssl rand -hex 32
OPENCLAW_TOKEN=

# --- Tailscale VPN ---

# [REQUIRED] Tailscale auth key (reusable recommended)
# Get one: https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# Tailscale hostname — appears in your dashboard and is used
# to access Control UI: http://<hostname>:18789
# Change this if running multiple instances
TS_HOSTNAME=openclaw-agent

# --- AI Provider ---

# [REQUIRED] At least ONE provider key is needed.
# Set your key AND the matching AI_MODEL below.

# Anthropic (recommended)
#ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# OpenAI
#OPENAI_API_KEY=sk-proj-xxxxxxxx

# OpenRouter (100+ models)
#OPENROUTER_API_KEY=sk-or-xxxxxxxx

# Google Gemini
#GEMINI_API_KEY=

# Groq (fast inference)
#GROQ_API_KEY=

# Mistral
#MISTRAL_API_KEY=

# AI model to use (must match your provider key above)
# Examples:
#   anthropic/claude-sonnet-4-20250514  (Anthropic)
#   anthropic/claude-opus-4-6       (Anthropic, expensive)
#   openai/gpt-4o                       (OpenAI)
#   openai/gpt-4o-mini                  (OpenAI, cheap)
#   google/gemini-2.0-flash             (Google)
AI_MODEL=anthropic/claude-sonnet-4-20250514

# --- Telegram ---

# [REQUIRED] Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# --- Optional: Additional Channels ---

#DISCORD_BOT_TOKEN=

# --- Optional: Tools & Services ---

#BRAVE_API_KEY=
#ELEVENLABS_API_KEY=
#ELEVENLABS_VOICE_ID=
#PERPLEXITY_API_KEY=
#DEEPGRAM_API_KEY=

# --- Optional: GitHub ---
# Fine-grained PATs for git push/pull inside the agent.
# Run ./scripts/setup-github.sh after first boot to wire them in.
# One token per owner (user OR org, not both in the same token).

#GITHUB_TOKEN_PICOINNO=github_pat_xxxxxxxxx    # picoinno personal account
#GITHUB_TOKEN_PICO_INNO=github_pat_xxxxxxxxx   # pico-inno org
#GITHUB_TOKEN_MIJN_UI=github_pat_xxxxxxxxx     # mijn-ui org (optional)
#GITHUB_TOKEN_SANNKOKO=github_pat_xxxxxxxxx    # sannkoko org (optional)
#GIT_USER_NAME=OpenClaw Agent
#GIT_USER_EMAIL=agent@openclaw.ai

# --- Optional: Advanced ---

# OpenAI-compatible endpoint (for Ollama, LiteLLM, etc.)
#OPENAI_BASE_URL=http://host.docker.internal:11434/v1

# Log level: error | warn | info | debug
OPENCLAW_LOG_LEVEL=info
