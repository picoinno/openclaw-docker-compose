# ============================================================
# OpenClaw Stack — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# Everything else is optional.
# ============================================================

# --- Core Security ---

# [REQUIRED] Gateway auth token — used for Control UI access
# Generate one: openssl rand -hex 32
OPENCLAW_TOKEN=

# --- Tailscale VPN ---

# [REQUIRED] Tailscale auth key (reusable recommended)
# Get one: https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# Tailscale hostname — appears in your dashboard and is used
# to access Control UI: http://<hostname>:18789
# Change this if running multiple instances
TS_HOSTNAME=openclaw-agent

# --- AI Provider ---

# [REQUIRED] At least ONE provider key is needed.
# Set your key AND the matching AI_MODEL below.
#
# Recommended setup: OpenRouter as primary (100+ models, best price/performance)
# with Anthropic + OpenAI as official fallbacks, and Ollama as local fallback.
# See openclaw.json.template for the full fallback chain.

# OpenRouter (recommended — access to 100+ models via one key)
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxx

# Anthropic (used as fallback — claude-sonnet-4-6)
# Get your key: https://console.anthropic.com/settings/keys
#ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# OpenAI (used as fallback — gpt-4o)
# Get your key: https://platform.openai.com/api-keys
#OPENAI_API_KEY=sk-proj-xxxxxxxx

# Google Gemini
#GEMINI_API_KEY=

# Groq (fast inference)
#GROQ_API_KEY=

# Mistral
#MISTRAL_API_KEY=

# AI model to use as primary (must match your active provider key above)
# Examples:
#   openrouter/qwen/qwen-3.5-72b-instruct   (OpenRouter — recommended default)
#   openrouter/google/gemini-2.5-flash      (OpenRouter — fast + cheap)
#   openrouter/minimax/minimax-m2.7         (OpenRouter — strong agent model)
#   anthropic/claude-sonnet-4-6             (Anthropic direct)
#   openai/gpt-4o                           (OpenAI direct)
AI_MODEL=openrouter/qwen/qwen-3.5-72b-instruct

# --- Telegram ---

# [REQUIRED] Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# --- Browser Security ---

# [REQUIRED] Random token to protect the headless browser endpoint
# Generate one: openssl rand -hex 32
BROWSER_TOKEN=

# --- Optional: Additional Channels ---

#DISCORD_BOT_TOKEN=

# --- Optional: Tools & Services ---

#BRAVE_API_KEY=
#ELEVENLABS_API_KEY=
#ELEVENLABS_VOICE_ID=
#PERPLEXITY_API_KEY=
#DEEPGRAM_API_KEY=

# --- Optional: GitHub ---
# Fine-grained PATs for git push/pull inside the agent.
# One token per owner (user OR org — not both in the same token).
# Set username + token pairs, then run ./scripts/setup-github.sh once.

#GITHUB_USERNAME_1=your-github-username
#GITHUB_TOKEN_1=github_pat_xxxxxxxxx

#GITHUB_USERNAME_2=your-org-name
#GITHUB_TOKEN_2=github_pat_xxxxxxxxx

# Add more pairs as needed: GITHUB_USERNAME_3, GITHUB_TOKEN_3, etc.

#GIT_USER_NAME=OpenClaw Agent
#GIT_USER_EMAIL=

# --- Optional: Advanced ---

# Ollama (local fallback — runs on your own hardware, no API cost)
# Point this to your Ollama instance. Use host.docker.internal to reach
# a locally running Ollama from inside the container.
# Download Ollama: https://ollama.com
#OLLAMA_BASE_URL=http://host.docker.internal:11434

# OpenAI-compatible endpoint (for LiteLLM, custom proxies, etc.)
#OPENAI_BASE_URL=http://host.docker.internal:11434/v1

# Log level: error | warn | info | debug
OPENCLAW_LOG_LEVEL=info
