# Core Security
OPENCLAW_TOKEN=your_strong_gateway_token

# Tailscale VPN
# Sign up at https://tailscale.com and generate an auth key at:
# https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxxxxx

# Tailscale hostname — appears in your Tailscale dashboard and is used
# to access the Control UI in your browser: http://<hostname>:18789
# Change this to something unique if running multiple instances
TS_HOSTNAME=openclaw-agent

# AI Brain (Anthropic Claude | OpenAI GPT-4)
#ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxx


# Telegram Channel
TELEGRAM_BOT_TOKEN=123456789:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
