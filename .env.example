# OpenClaw Environment Variables
# Copy this file to .env and fill in the values.
# Do NOT commit the .env file to version control.

# --- Core Infrastructure ---
TS_HOSTNAME=openclaw-agent
TS_AUTHKEY=
OPENCLAW_TOKEN=
BROWSER_TOKEN=

# --- AI Provider API Keys (at least one is required) ---
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# OPENAI_BASE_URL=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# --- GitHub Credentials (for git operations) ---
GITHUB_USERNAME_1=
GITHUB_TOKEN_1=
# GITHUB_USERNAME_2=
# GITHUB_TOKEN_2=
GIT_USER_NAME="MyanClaw"
GIT_USER_EMAIL="agent@pico-inno.com"

# --- Optional Services ---
# PERPLEXITY_API_KEY=
# BRAVE_API_KEY=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# DEEPGRAM_API_KEY=
